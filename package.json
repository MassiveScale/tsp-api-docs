{
  "name": "@massivescale/tsp-api-docs",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    }
  },
  "peerDependencies": {
    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/versioning": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "handlebars": "^4.7.8",
    "typescript-eslint": "^8.49.0",
    "eslint": "^9.15.0",
    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/versioning": "latest",
    "typescript": "^5.3.3",
    "prettier": "^3.3.3"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "npm run build && node --test test/**/*.test.js",
    "lint": "eslint src/ test/ --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "format": "prettier .  --write",
    "format:check": "prettier --check ."
  },
  "private": true,
  "packageManager": "npm@11.14.1+sha512.6a8a4d67478497a2dbc6815cad72e64c43f33413717e242756047d466241ab39bee61e691683a64658e94496ec5f1a1c05e4a5ec62dcc773280dfd949443a367"
}